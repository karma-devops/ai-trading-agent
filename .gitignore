# ============================================================================
# AI Trading Agent - HyperLiquid (Private)
# Clean .gitignore
# ============================================================================

# Secrets - NEVER commit
.env
.env.*
!.env_example
*.key
*.pem
secrets.json
**/user_secrets.json
**/user_settings.json
**/user_tiers.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
trading_venv/

# Runtime data (generated at startup, not committed)
src/data/
temp_data/
logs/
*.log
*.log.*
*.sqlite
*.db

# Backtest artifacts (removed, never coming back)
*.html

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.cursorrules

# Build / packaging
build/
dist/
.cache/

# Docker
docker-compose.override.yml

# Large data files
*.csv.gz
*.parquet
*.csv