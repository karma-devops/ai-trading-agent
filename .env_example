# ============================================================================
# AI Trading Agent - HyperLiquid (Private)
# Environment Variables Template
# ============================================================================
#
# HOW TO SET THESE
# ----------------
# Local development:
#   1. Copy this file to .env
#   2. Fill in the REQUIRED values below
#   3. Run: python trading_app.py
#
# EasyPanel deployment (zip upload):
#   1. Download the repo as a ZIP.
#   2. In EasyPanel, create a project and choose "Deploy from Dockerfile" or "Upload".
#   3. Upload the ZIP.
#   4. In the EasyPanel "Environment" tab, add EACH variable below one-by-one.
#      Do NOT upload a .env file to EasyPanel; paste values into the UI.
#   5. Expose port 5000 (or set PORT below to the port EasyPanel gives you).
#   6. Start the container. The health check pings /api/status.
#
# Required for the app to start:
#   - FLASK_SECRET_KEY
#   - DASHBOARD_USERNAME
#   - DASHBOARD_PASSWORD  (plaintext; hashed automatically on first login)
#   - HYPER_LIQUID_ETH_PRIVATE_KEY  (or ACCOUNT_ADDRESS + HYPER_LIQUID_KEY if applicable)
#
# Required only if you want external agents (like me) to control it:
#   - AGENT_API_KEY  (a long random string you share with the remote tool)
#
# Optional keys depend on which AI provider you select in Settings:
#   - OPENROUTER_API_KEY  (default alternative)
#   - ANTHROPIC_KEY, OPENAI_KEY, DEEPSEEK_KEY, GROQ_API_KEY, GEMINI_KEY
#
# ⚠️ NEVER COMMIT THE ACTUAL .env FILE. This template is safe to commit.
# 🔒 Rotate any key immediately if it is accidentally exposed.
# ============================================================================

# 🎯 DASHBOARD CONFIGURATION (Required)
# ============================================================================

# Flask Secret Key (CRITICAL for session security)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_strong_random_secret_key_here_64_characters_minimum

# Dashboard Login Credentials
DASHBOARD_USERNAME=your_dashboard_username
DASHBOARD_EMAIL=your_dashboard_email@example.com
DASHBOARD_PASSWORD=your_secure_dashboard_password

# Server Port (optional, defaults to 5000)
PORT=5000

# ============================================================================
# 💱 TRADING APIS
# ============================================================================

# HyperLiquid Trading (required)
# EasyPanel: paste the private key from your HyperLiquid "API" / wallet export.
# This is the EVM private key used to sign orders. Keep it secret.
HYPER_LIQUID_ETH_PRIVATE_KEY=your_hyper_liquid_eth_private_key_here

# Optional: explicit HyperLiquid account address.
# Leave blank if the address can be derived from HYPER_LIQUID_ETH_PRIVATE_KEY.
ACCOUNT_ADDRESS=

# Optional legacy APIs (not used in HyperLiquid-only mode)
BIRDEYE_API_KEY=your_birdeye_api_key_here
RPC_ENDPOINT=your_helius_rpc_endpoint_here
MOONDEV_API_KEY=your_moondev_key_here



# AI Service Keys
ANTHROPIC_KEY=your_claude_key_here
OPENAI_KEY=your_openai_key_here
DEEPSEEK_KEY=your_deepseek_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_KEY=your-gemini-key
GROK_API_KEY=xai-OZ
OPENROUTER_API_KEY=your_openrouter_key_here  # 🌙 Moon Dev: Access 200+ models at openrouter.ai

# YouTube API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Restream API Key
RESTREAM_CLIENT_ID=your_client_id
RESTREAM_CLIENT_SECRET=your_client_secret
RESTREAM_EMBED_TOKEN=your_chat_token

# Twilio Configuration (Required for phone agent)
TWILIO_ACCOUNT_SID=AC********************************
TWILIO_AUTH_TOKEN=********************************
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number



# twitter keys 
TWITTER_USERNAME=your_twitter_username_here
TWITTER_EMAIL=your_twitter_email_here
TWITTER_PASSWORD=your_twitter_password_here

# google keys
GOOGLE_APPLICATION_CREDENTIALS=your_google_credentials_path

COINGECKO_API_KEY=your_coingecko_api_key_here

# 🚨 SECURITY REMINDERS:
# 1. Never print these values in logs
# 2. Never share your .env file
# 3. Never commit this file (use .env example instead)
# 4. Revoke and rotate keys if accidentally exposed
# 5. Keep your Moon Dev secrets safe! 🌙 

# AI Provider (BYOK)
# EasyPanel: these set the default AI provider/model. They can also be changed
# later from the dashboard Settings tab.
# AI_PROVIDER options: ollama, openrouter, huggingface, generic_openai
AI_PROVIDER=ollama
AI_MODEL=kimi-k2.7-code

# Optional override for the AI endpoint.
# Examples: https://ollama.com/v1  or  https://api.openrouter.ai/v1
AI_BASE_URL=
AI_API_KEY=

# Strategy: confidence_ai (default) or engine_v6_1
ACTIVE_STRATEGY=confidence_ai

# Safety
# EasyPanel: ALWAYS start with DRY_RUN=true until you verify sizing/strategy live.
# When true, the agent logs intended trades but does NOT send orders.
DRY_RUN=true

# Remote Agent API Key
# EasyPanel: set this to a long random string if you want an external agent/tool
# (e.g. Hermes) to start/stop the agent and change settings via REST.
# Pass the same value in the X-Agent-API-Key or Authorization: Bearer header.
AGENT_API_KEY=your_random_32_char_key_here
